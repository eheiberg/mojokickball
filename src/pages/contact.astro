---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { WEB3FORMS_ACCESS_KEY } from '~/data/site';

const metadata = {
  title: 'Contact',
};
---
<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Get in Touch"
    subtitle="Questions about Mojo? Want to bring the league to your city? We'd love to hear from you."
  />

  <!-- Contact Form via Web3Forms -->
  <section class="py-8 px-4">
    <div class="max-w-xl mx-auto rounded-2xl border border-gray-200 bg-white shadow-md p-8">
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        id="contact-form"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="MojoKickball Website Contact" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div class="mb-5">
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          />
        </div>

        <div class="mb-5">
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          />
        </div>

        <div class="mb-6">
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          ></textarea>
        </div>

        <div class="h-captcha" data-captcha="true"></div>
        <button
          type="submit"
          class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-6 rounded-xl transition-colors"
        >
          Send Message
        </button>

        <div id="form-success" class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-300 rounded-lg text-emerald-800 text-center font-medium">
          Thanks for submitting! We'll get back to you soon.
        </div>
        <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-300 rounded-lg text-red-700 text-center">
          Something went wrong. Please try again or email us directly.
        </div>
      </form>
    </div>
  </section>

  <script src="https://web3forms.com/client/script.js" async defer></script>
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      if (res.ok) {
        form.reset();
        document.getElementById('form-success')!.classList.remove('hidden');
      } else {
        document.getElementById('form-error')!.classList.remove('hidden');
      }
    });
  </script>

  <Features2
    title="Other ways to connect"
    columns={3}
    items={[
      {
        title: 'Facebook Group',
        description: 'Join the Facebook group for game updates, cancellations, and community conversations.',
        icon: 'tabler:brand-facebook',
      },
      {
        title: 'YouTube',
        description: 'Watch the tutorial video and other Mojo content on our YouTube channel.',
        icon: 'tabler:brand-youtube',
      },
      {
        title: 'Just show up',
        description: 'No appointment needed — come to Kenwood Park Field #2 any Sunday at 1pm and join the game.',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
