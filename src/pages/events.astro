---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import seasonData from '~/data/events/2026.json';

const metadata = {
  title: '2026 Season Events',
};

const eventsJson = JSON.stringify(seasonData.events);
const season = seasonData.season;
const location = seasonData.location;
const address = seasonData.address;
const mapsUrl = seasonData.mapsUrl;
const defaultMetaJson = JSON.stringify({
  location: seasonData.location,
  address: seasonData.address,
  mapsUrl: seasonData.mapsUrl,
});
---

<Layout metadata={metadata}>
  <HeroText
    tagline={`${season} Season`}
    title="All Events"
    subtitle={`Every Sunday · 1:00 PM – 3:00 PM CDT · ${location}`}
  />

  <section class="py-8 px-4 max-w-3xl mx-auto">
    <div class="mb-6 text-center text-sm text-gray-500">
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="underline text-blue-600 hover:text-blue-700">
        {address}
      </a>
    </div>

    <div id="events-list" class="space-y-3">
      <!-- Populated by JavaScript below -->
    </div>

    <noscript>
      <p class="text-center text-gray-500 py-8">Please enable JavaScript to view the events list.</p>
    </noscript>

    <p class="text-center mt-8 text-sm text-gray-400">
      Rain-out updates are posted to the
      <a href="https://www.facebook.com/groups/mojokickball" target="_blank" rel="noopener noreferrer" class="underline text-blue-600">Facebook group</a>.
    </p>
  </section>
</Layout>

<script define:vars={{ eventsJson, season, mapsUrl, defaultMetaJson }}>
  const events = JSON.parse(eventsJson);
  const defaultMeta = JSON.parse(defaultMetaJson);
  const now = new Date();

  function resolveMeta(e) {
    return {
      location: e.location ?? defaultMeta.location,
      address: e.address ?? defaultMeta.address,
      mapsUrl: e.mapsUrl ?? defaultMeta.mapsUrl,
    };
  }

  function formatDate(dateStr) {
    return new Date(dateStr + 'T12:00:00-05:00').toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      timeZone: 'America/Chicago',
    });
  }

  function isPast(dateStr) {
    return new Date(dateStr + 'T15:00:00-05:00') < now;
  }

  function isNext(e, index) {
    // The first non-past event
    const firstFutureIndex = events.findIndex((ev) => !isPast(ev.date));
    return index === firstFutureIndex;
  }

  const list = document.getElementById('events-list');
  list.innerHTML = events
    .map((e, i) => {
      const past = isPast(e.date);
      const next = isNext(e, i);
      const cancelled = e.cancelled;
      const tourney = e.isTourney;
      const special = e.isSpecial;
      const meta = resolveMeta(e);

      let badge = '';
      if (cancelled) {
        badge = '<span class="ml-2 text-xs font-bold bg-red-100 text-red-700 px-2 py-0.5 rounded-full">CANCELLED</span>';
      } else if (next) {
        badge = '<span class="ml-2 text-xs font-bold bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full">NEXT GAME</span>';
      }
      if (special && !cancelled) {
        badge += '<span class="ml-2 text-xs font-bold bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">SPECIAL EVENT</span>';
      } else if (tourney && !cancelled) {
        badge += '<span class="ml-2 text-xs font-bold bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">TOURNEY DAY</span>';
      }

      const rowClass = past
        ? 'opacity-50'
        : next
          ? 'ring-2 ring-emerald-400 bg-emerald-50'
          : cancelled
            ? 'bg-red-50'
            : special
              ? 'bg-amber-50 hover:bg-amber-100'
              : 'bg-white hover:bg-gray-50';

      const addressHtml = `<a href="${meta.mapsUrl}" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 hover:underline">${meta.address}</a>`;

      return `
        <div class="flex items-center justify-between rounded-xl border border-gray-200 px-5 py-4 ${rowClass} transition-colors">
          <div>
            <div>
              <span class="font-semibold text-gray-900 ${cancelled ? 'line-through decoration-red-400' : ''}">${formatDate(e.date)}</span>
              ${badge}
              ${tourney && !cancelled ? '<a href="/the-great-mojo-tourney" class="ml-2 text-xs underline text-blue-600">Tournament details →</a>' : ''}
            </div>
            <div class="mt-0.5">${addressHtml}</div>
          </div>
          <div class="text-sm text-gray-500 text-right">
            ${past ? '<span class="text-xs text-gray-400">Past</span>' : '<span class="text-xs text-gray-500">1–3 PM CDT</span>'}
          </div>
        </div>
      `;
    })
    .join('');
</script>
