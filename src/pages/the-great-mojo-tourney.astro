---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'The Great Mojo Tourney',
};

const tourneyDate = 'Sunday, October 4, 2026';
const tourneyTime = '1:00 PM CDT';
const tourneyLocation = 'Kenwood Park Field #2, Minneapolis';
const registrationUrl = 'https://forms.google.com/'; // Replace with actual Google Form URL
---

<Layout metadata={metadata}>
  <Hero tagline="Annual Tournament">
    <Fragment slot="title">
      The Great <span class="text-accent">Mojo Tourney</span>
    </Fragment>
    <Fragment slot="subtitle">
      The season finale. Previous Mojo participants form lottery teams and compete for the ultimate honor: the Mojo Cup.
      <span class="block mt-2 font-semibold">{tourneyDate} · {tourneyTime} · {tourneyLocation}</span>
    </Fragment>
  </Hero>

  <!-- Format -->
  <Steps
    title="How the Tournament Works"
    tagline="Format"
    items={[
      {
        title: 'Only previous participants can enter',
        description:
          'The tournament is open to anyone who has played in a Twin Cities Mojo game during the season. First-time players can come and watch (or serve as judges!).',
        icon: 'tabler:user-check',
      },
      {
        title: 'Teams are assigned by lottery',
        description:
          'No picking teams. All registered players go into a lottery and are randomly assigned to teams of 8. Two to four teams compete depending on turnout.',
        icon: 'tabler:dice',
      },
      {
        title: 'Teams choose their own captain and name',
        description:
          'Once teams are assigned, players pick a captain and come up with a team name. Part of the fun.',
        icon: 'tabler:crown',
      },
      {
        title: 'Play Mojo rules — timed, unsupervised',
        description:
          'Games follow standard Mojo rules with timed quarters. In the true spirit of Mojo, teams self-officiate and keep their own score.',
        icon: 'tabler:clock',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1540747913346-19e32dc3e97e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2053&q=80',
      alt: 'Trophy award ceremony',
    }}
  />

  <!-- Awards -->
  <Features2
    title="The Awards"
    subtitle="Two trophies. Two very different paths to victory."
    columns={2}
    items={[
      {
        title: 'Most Points Award',
        description:
          'Awarded to the team with the highest run total across the tournament. Pure scoreboard dominance.',
        icon: 'tabler:trophy',
      },
      {
        title: 'The Mojo Cup',
        description:
          'The perpetual trophy. Awarded by the judges based on "Spirit of Mojo" — recognizing the team that best embodies sportsmanship, teamwork, and Inclusion with Contribution. The Mojo Cup is the one that really matters.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Registration -->
  <section class="py-12 px-4">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Register for the Tournament</h2>
      <p class="text-gray-600 mb-6">
        If you've played a Mojo game this season, you're eligible. Register using the form below before the tournament date.
      </p>
      <a
        href={registrationUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent hover:opacity-90 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-opacity"
      >
        Register via Google Form
      </a>
      <p class="mt-4 text-sm text-gray-500">
        Not registered yet for regular season games?
        <a href="https://www.eventbrite.com/e/mojo-kickball-tickets" class="underline text-blue-600" target="_blank">Register on EventBrite →</a>
      </p>
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Join a Regular Game First',
        href: '/events',
      },
      {
        text: 'Learn the Rules',
        href: '/tutorial',
      },
    ]}
  >
    <Fragment slot="title">New to Mojo?</Fragment>
    <Fragment slot="subtitle">
      You need to have played at least one regular season game to be eligible for the tournament.
      Come out on any Sunday — first-timers are always welcome.
    </Fragment>
  </CallToAction>
</Layout>
