---
import seasonData from '~/data/events/2026.json';

const eventsJson = JSON.stringify(seasonData.events);
const defaultMeta = {
  location: seasonData.location,
  address: seasonData.address,
  mapsUrl: seasonData.mapsUrl,
};
const defaultMetaJson = JSON.stringify(defaultMeta);
---

<section class="py-10 px-4">
  <div class="max-w-2xl mx-auto">
    <!-- Upcoming game card -->
    <div
      id="event-upcoming"
      class="hidden rounded-2xl border-2 p-8 text-center shadow-md"
    >
      <div id="event-type-label" class="text-xs font-bold uppercase tracking-widest mb-3"></div>
      <h3 id="event-date" class="text-3xl font-extrabold text-gray-900 mb-1"></h3>
      <p id="event-time" class="text-lg text-gray-600 font-medium">1:00 PM – 3:00 PM CDT</p>
      <p class="text-gray-500 mt-3 leading-relaxed">
        <span id="event-location" class="font-medium text-gray-700"></span><br />
        <span id="event-address" class="text-sm"></span>
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <div class="relative">
          <button
            id="event-calendar-btn"
            type="button"
            class="inline-flex items-center gap-1 text-white font-semibold px-7 py-3 rounded-xl transition-colors"
          >
            Add to Calendar <span aria-hidden="true">▾</span>
          </button>
          <div
            id="calendar-dropdown"
            class="hidden absolute left-0 top-full mt-1 z-10 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden min-w-full"
          >
            <a
              id="event-gcal-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors"
            >Google Calendar</a>
            <button
              id="event-ics-btn"
              type="button"
              class="block w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors"
            >Download .ics</button>
          </div>
        </div>
        <a
          id="event-maps-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-2 border-gray-300 hover:border-gray-400 text-gray-700 font-semibold px-7 py-3 rounded-xl transition-colors"
        >
          Get Directions
        </a>
      </div>
      <p class="mt-5 text-sm text-gray-400">
        <a href="/events" class="underline hover:text-gray-600">See all 2026 events →</a>
      </p>
    </div>

    <!-- Cancelled game card -->
    <div
      id="event-cancelled"
      class="hidden rounded-2xl border-2 border-red-400 bg-red-50 p-8 text-center shadow-md"
    >
      <div class="text-xs font-bold text-red-700 uppercase tracking-widest mb-3">⚠ Game Cancelled</div>
      <h3 id="event-cancelled-date" class="text-3xl font-extrabold text-gray-900 mb-1 line-through decoration-red-400"></h3>
      <p class="text-lg text-gray-500 font-medium">1:00 PM – 3:00 PM CDT</p>
      <p class="text-gray-500 mt-3 leading-relaxed">
        <span id="event-cancelled-location" class="font-medium text-gray-700"></span><br />
        <span id="event-cancelled-address" class="text-sm"></span>
      </p>
      <p class="text-red-700 font-semibold mt-4">This week's game has been cancelled.</p>
      <p class="text-gray-500 mt-2 text-sm">
        Check the
        <a
          href="https://www.facebook.com/groups/mojokickball"
          target="_blank"
          rel="noopener noreferrer"
          class="underline text-blue-600 hover:text-blue-700"
        >Facebook group</a>
        for updates.
      </p>
      <p class="mt-5 text-sm text-gray-400">
        <a href="/events" class="underline hover:text-gray-600">See all 2026 events →</a>
      </p>
    </div>

    <!-- Off-season card -->
    <div
      id="event-offseason"
      class="hidden rounded-2xl border-2 border-gray-200 bg-gray-50 p-8 text-center shadow-md"
    >
      <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Off Season</div>
      <h3 class="text-2xl font-extrabold text-gray-700 mb-2">See you next season!</h3>
      <p class="text-gray-500 leading-relaxed">
        Mojo Kickball runs every Sunday from mid-May through early October.<br />
        Stay tuned for the 2027 season.
      </p>
      <p class="mt-5 text-sm">
        <a href="/events" class="underline text-blue-600 hover:text-blue-700">View 2026 season events →</a>
      </p>
    </div>
  </div>
</section>

<script define:vars={{ eventsJson, defaultMetaJson }}>
  const events = JSON.parse(eventsJson);
  const defaultMeta = JSON.parse(defaultMetaJson);

  function resolveMeta(event) {
    return {
      location: event.location ?? defaultMeta.location,
      address: event.address ?? defaultMeta.address,
      mapsUrl: event.mapsUrl ?? defaultMeta.mapsUrl,
    };
  }

  function buildGcalUrl(dateStr, meta) {
    const d = dateStr.replace(/-/g, '');
    const params = new URLSearchParams({
      action: 'TEMPLATE',
      text: 'Mojo Kickball',
      dates: `${d}T130000/${d}T150000`,
      ctz: 'America/Chicago',
      details: 'Free pickup kickball! No registration required.',
      location: `${meta.location}, ${meta.address}`,
    });
    return `https://calendar.google.com/calendar/render?${params}`;
  }

  function buildIcsContent(dateStr, meta) {
    const d = dateStr.replace(/-/g, '');
    const loc = `${meta.location}\\, ${meta.address}`;
    return [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//Mojo Kickball//EN',
      'BEGIN:VEVENT',
      `DTSTART;TZID=America/Chicago:${d}T130000`,
      `DTEND;TZID=America/Chicago:${d}T150000`,
      'SUMMARY:Mojo Kickball',
      'DESCRIPTION:Free pickup kickball! No registration required.',
      `LOCATION:${loc}`,
      `UID:mojo-kickball-${dateStr}@mojokickball.com`,
      'END:VEVENT',
      'END:VCALENDAR',
    ].join('\r\n');
  }

  function downloadIcs(dateStr, meta) {
    const blob = new Blob([buildIcsContent(dateStr, meta)], { type: 'text/calendar' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'mojo-kickball.ics';
    a.click();
    URL.revokeObjectURL(url);
  }

  function getDisplayEvent() {
    const now = new Date();
    // Show the first event whose end time (3pm CDT = 20:00 UTC) hasn't passed
    return events.find((e) => new Date(e.date + 'T15:00:00-05:00') > now) || null;
  }

  function formatDate(dateStr) {
    return new Date(dateStr + 'T12:00:00-05:00').toLocaleDateString('en-US', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'America/Chicago',
    });
  }

  const event = getDisplayEvent();

  if (event) {
    const meta = resolveMeta(event);

    if (event.cancelled) {
      document.getElementById('event-cancelled-date').textContent = formatDate(event.date);
      document.getElementById('event-cancelled-location').textContent = meta.location;
      document.getElementById('event-cancelled-address').textContent = meta.address;
      document.getElementById('event-cancelled').classList.remove('hidden');
    } else {
      const card = document.getElementById('event-upcoming');
      const typeLabel = document.getElementById('event-type-label');
      const calendarBtn = document.getElementById('event-calendar-btn');
      const dropdown = document.getElementById('calendar-dropdown');

      if (event.isSpecial) {
        card.classList.add('border-amber-400', 'bg-amber-50');
        typeLabel.textContent = 'Special Event';
        typeLabel.classList.add('text-amber-700');
        calendarBtn.classList.add('bg-amber-600', 'hover:bg-amber-700');
      } else {
        card.classList.add('border-emerald-400', 'bg-emerald-50');
        typeLabel.textContent = 'Next Game';
        typeLabel.classList.add('text-emerald-700');
        calendarBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-700');
      }

      document.getElementById('event-date').textContent = formatDate(event.date);
      document.getElementById('event-location').textContent = meta.location;
      document.getElementById('event-address').textContent = meta.address;
      document.getElementById('event-gcal-link').href = buildGcalUrl(event.date, meta);
      document.getElementById('event-maps-link').href = meta.mapsUrl;

      calendarBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown.classList.toggle('hidden');
      });

      document.getElementById('event-ics-btn').addEventListener('click', () => {
        downloadIcs(event.date, meta);
        dropdown.classList.add('hidden');
      });

      document.addEventListener('click', () => dropdown.classList.add('hidden'));

      card.classList.remove('hidden');
    }
  } else {
    document.getElementById('event-offseason').classList.remove('hidden');
  }
</script>
